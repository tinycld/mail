{
    "compilerOptions": {
        "paths": {
            "~/*": ["./*"]
        },
        "strict": true,
        "rootDir": ".",
        "module": "Preserve",
        "moduleResolution": "Bundler",
        "preserveSymlinks": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "noImplicitAny": false,
        "types": ["node", "react", "vite/client"],
        "lib": ["dom", "esnext"]
    },
    "exclude": [
        "node_modules",
        ".expo",
        "**/test",
        "**/dist",
        "node_modules/**/types",
        "**/__tests__",
        "ideas"
    ],
    "typeAcquisition": {
        "enable": true
    }
}
